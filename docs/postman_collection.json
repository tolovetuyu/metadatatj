{
  "info": {
    "name": "MetadataTJ API",
    "description": "MetadataTJ 数据元推荐服务接口测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:7058",
      "description": "服务基础地址"
    }
  ],
  "item": [
    {
      "name": "推荐服务",
      "item": [
        {
          "name": "字段推荐接口",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lybEname\": \"\",\n  \"fieldsInfo\": [\n    {\n      \"cname\": \"姓名\",\n      \"ename\": \"name\",\n      \"type\": \"string\",\n      \"length\": 255\n    },\n    {\n      \"cname\": \"证件号码\",\n      \"ename\": \"idcard\",\n      \"type\": \"string\",\n      \"length\": 18\n    },\n    {\n      \"cname\": \"性别\",\n      \"ename\": \"gender\",\n      \"type\": \"string\",\n      \"length\": 10\n    },\n    {\n      \"cname\": \"出生日期\",\n      \"ename\": \"birthday\",\n      \"type\": \"date\",\n      \"length\": 10\n    },\n    {\n      \"cname\": \"联系电话\",\n      \"ename\": \"phone\",\n      \"type\": \"string\",\n      \"length\": 20\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/recommendWithExtend",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "recommendWithExtend"]
            },
            "description": "字段推荐接口，返回每个字段对应的数据元推荐结果（Top5）"
          },
          "response": []
        },
        {
          "name": "字段推荐-单个字段",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lybEname\": \"\",\n  \"fieldsInfo\": [\n    {\n      \"cname\": \"姓名\",\n      \"ename\": \"xm\",\n      \"type\": \"string\",\n      \"length\": 255\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/recommendWithExtend",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "recommendWithExtend"]
            }
          },
          "response": []
        },
        {
          "name": "字段推荐-带限定词",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lybEname\": \"\",\n  \"fieldsInfo\": [\n    {\n      \"cname\": \"户籍地\",\n      \"ename\": \"hjd\",\n      \"type\": \"string\",\n      \"length\": 255\n    },\n    {\n      \"cname\": \"现住地\",\n      \"ename\": \"xzd\",\n      \"type\": \"string\",\n      \"length\": 255\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/recommendWithExtend",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "recommendWithExtend"]
            },
            "description": "测试带限定词的字段推荐（如户籍地、现住地等）"
          },
          "response": []
        }
      ]
    },
    {
      "name": "通用字段",
      "item": [
