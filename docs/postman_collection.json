                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"primaryKeyFields\": [\n    \"id\",\n    \"name\"\n  ],\n  \"RUN_SJLYXTFLDM\": \"01001\",\n  \"RUN_CJD_XZQHDM\": \"610000\",\n  \"RUN_SJJLMGJB\": \"99\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/commonFields",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "commonFields"]
            },
            "description": "RUN通用字段推荐接口，返回标准RUN字段列表"
          },
          "response": []
        },
        {
          "name": "RUN通用字段-简化参数",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
