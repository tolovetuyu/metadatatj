    {
      "name": "历史推荐管理",
      "item": [
        {
          "name": "全量同步-从task_process",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force_full\": true,\n  \"source\": \"task_process\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/history/sync",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "history", "sync"]
            },
            "description": "从rucp_task_process表全量同步历史推荐数据"
          },
          "response": []
        },
        {
          "name": "全量同步-从mapping_history",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force_full\": true,\n  \"source\": \"mapping_history\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/history/sync",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "history", "sync"]
            },
            "description": "从rucp_element_mapping_history表全量同步历史推荐数据"
          },
          "response": []
        },
        {
          "name": "全量同步-所有数据源",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force_full\": true,\n  \"source\": \"all\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/history/sync",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "history", "sync"]
            },
            "description": "从所有数据源全量同步历史推荐数据"
          },
          "response": []
        },
        {
          "name": "增量同步",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force_full\": false,\n  \"source\": \"task_process\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/history/sync",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "history", "sync"]
            },
            "description": "增量同步历史推荐数据（基于ID自增）"
          },
          "response": []
        },
        {
          "name": "查看历史统计",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/autoexport/api/history/stats",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "history", "stats"]
            },
            "description": "查看历史推荐缓存统计信息"
          },
          "response": []
        }
      ]
    },
    {
      "name": "健康检查",
      "item": [
        {
          "name": "服务健康检查",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fieldsInfo\": []\n}"
            },
            "url": {
              "raw": "{{base_url}}/autoexport/api/recommend",
              "host": ["{{base_url}}"],
              "path": ["autoexport", "api", "recommend"]
            },
            "description": "健康检查接口，返回空结果表示服务正常"
          },
          "response": []
        }
      ]
    }
  ]
}