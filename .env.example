# ========== 服务 ==========
RECOMMEND_HOST=0.0.0.0
RECOMMEND_PORT=6058
TABLEMAP_HOST=0.0.0.0
TABLEMAP_PORT=6061
ADMIN_HOST=0.0.0.0
ADMIN_PORT=6070
ADMIN_SECRET_KEY=change-me-in-production
UPLOAD_DIR=./data/uploads

# 知识库目录（使用项目内置目录）
KNOWLEDGE_DIR=./knowledge

# 向量库持久化目录（推荐 ChromaDB，单机 ~2 万条量级足够）
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# ========== 大模型（OpenAI 兼容 API）==========
# 支持 OpenAI / Azure / DashScope / DeepSeek / Ollama 等
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60
LLM_TEMPERATURE=0

# ========== Embedding（可与 LLM 同厂商或分开配置）==========
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TIMEOUT=60

# ========== 检索与精排 ==========
RECALL_TOP_K=30
RERANK_TOP_K=5
ELEMENT_SCORE_THRESHOLD=0.0
QUALIFIER_SCORE_THRESHOLD=0.0
TABLE_MATCH_THRESHOLD=0.75
FIELD_MATCH_THRESHOLD=0.80

# 关闭 LLM 时仅走向量召回（MVP / 降级模式）
LLM_DECOMPOSE_ENABLED=true
LLM_RERANK_ENABLED=true

# ========== 数据库配置 ==========
# 数据加载模式: "db" 从数据库读取, "file" 从文件读取
DATA_SOURCE=file

# 主数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=metadata
DB_CHARSET=utf8mb4

# 历史推荐数据库配置（独立数据库）
HISTORY_DB_HOST=localhost
HISTORY_DB_PORT=3306
HISTORY_DB_USER=root
HISTORY_DB_PASSWORD=
HISTORY_DB_NAME=metadata_history
HISTORY_DB_CHARSET=utf8mb4

# ========== 历史推荐配置 ==========
# 是否启用历史推荐（人工推荐历史优先）
HISTORY_RECOMMEND_ENABLED=false
# 历史推荐统计表名
HISTORY_RECOMMEND_TABLE=rucp_history_recommend_stat
# 历史推荐源数据表名
HISTORY_SOURCE_TABLE=rucp_element_mapping_history
# 历史推荐同步间隔（小时）
HISTORY_SYNC_INTERVAL_HOURS=24
# 历史推荐最小匹配次数阈值（默认超过5次才纳入统计）
HISTORY_MIN_MATCH_COUNT=5

# 人工对标过程表名
TASK_PROCESS_TABLE=rucp_task_process
